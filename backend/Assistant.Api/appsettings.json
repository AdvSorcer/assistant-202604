{
  "ConnectionStrings": {
    "Default": "Data Source=./data/assistant.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:18080"
    ]
  },
  "AutomaticBackup": {
    "Enabled": true,
    "TimeOfDay": "02:00",
    "TimeZone": "Asia/Taipei",
    "RetentionCount": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
